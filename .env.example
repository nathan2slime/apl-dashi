# PostgreSQL Configuration
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="root"
POSTGRES_DB="root"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"

# Redis Configuration
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="root"

# Node Environment
NODE_ENV="development"

# Database URL
DATABASE_URL="postgresql://postgres:root@localhost:5432/root?schema=public"

# Authentication Configuration
SESSION_EXPIRES_IN="24h"
SESSION_COOKIE="pulso_auth"
SESSION_KEY="<YOUR_RANDOMLY_GENERATED_SESSION_KEY>"

# Application Configuration
CLIENT_URL="http://localhost:3000"
PORT="5400"

# Add this line for production environment
CI="true"

# MinIO Configuration
MINIO_ROOT_USER="admin"
MINIO_ROOT_PASSWORD=

# S3 Configuration
S3_ENDPOINT="http://minio:9000"
S3_ACCESS_KEY="admin"
S3_SECRET_KEY=
S3_BUCKET="uploads"
S3_REGION="us-east-1"
